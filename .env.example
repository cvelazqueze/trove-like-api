# Copy this file to .env and replace every CHANGE_ME_* value before running Docker.
#   cp .env.example .env
#
# PostgreSQL + Redis below match docker-compose defaults (no placeholders).
# Replace every CHANGE_ME_* value for JWT and seed before running.
#
# Do not commit .env — it is gitignored.

# --- Application ---
NODE_ENV=development
PORT=3000
APP_HOST=localhost
API_PREFIX=/api

# --- PostgreSQL (app + postgres container) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME_db_user
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=CHANGE_ME_db_name
POSTGRES_SCHEMA=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Auth (generate a strong secret, e.g. openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_jwt_secret_min_16_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Cache ---
CACHE_TRENDING_TTL_SECONDS=300
CACHE_TRENDING_KEY_PREFIX=products:trending

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Socket.io ---
SOCKET_CORS_ORIGIN=*
SOCKET_PATH=/socket.io
SOCKET_ROOM_PREFIX=collection:

# --- Logging ---
# LOG_LEVEL=debug

# --- Database seed (required when RUN_SEED=true) ---
RUN_SEED=true
SEED_USER_EMAIL=CHANGE_ME_seed_email@example.com
SEED_USER_PASSWORD=CHANGE_ME_seed_password
SEED_USER_NAME=CHANGE_ME_seed_display_name
SEED_COLLECTION_NAME=CHANGE_ME_collection_name
SEED_PRODUCTS_JSON=[{"name":"Sample Product A","description":"Example item","price":19.99},{"name":"Sample Product B","description":"Example item","price":29.99}]
